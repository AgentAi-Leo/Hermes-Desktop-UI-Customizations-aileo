#!/usr/bin/env bash
set -euo pipefail
ROOT="/Users/jb3/.hermes/hermes-agent"
PYTHON="$ROOT/venv/bin/python"
WEB="$ROOT/web"
TARGET="$WEB/src/lib/briefs.ts"
FOCUSED_TEST="$WEB/src/lib/briefs.v44.test.ts"
STAMP="$(date +%Y%m%d-%H%M%S)"
BACKUP="$HOME/.hermes/backups/briefs-ai-compact-header-v44-$STAMP"
if [[ ! -x "$PYTHON" ]]; then echo "Missing Hermes Python: $PYTHON" >&2; exit 1; fi
if [[ ! -f "$TARGET" || ! -f "$WEB/package.json" ]]; then echo "Missing Hermes Briefs source" >&2; exit 1; fi
restore() {
  rm -f "$FOCUSED_TEST"
  if [[ -f "$BACKUP/web/src/lib/briefs.ts" ]]; then
    cp "$BACKUP/web/src/lib/briefs.ts" "$TARGET"
    (cd "$WEB" && npm run build) >/dev/null 2>&1 || true
    echo "RESTORED_AFTER_FAILURE=$BACKUP" >&2
  fi
}
trap 'r=$?; if [[ $r -ne 0 ]]; then restore; else rm -f "$FOCUSED_TEST"; fi; exit $r' EXIT
"$PYTHON" - "$ROOT" "$BACKUP" <<'PY'
import base64, hashlib, os, shutil, sys
from pathlib import Path
root=Path(sys.argv[1]); backup=Path(sys.argv[2]); target=root/'web/src/lib/briefs.ts'
original=target.read_bytes()
for marker in (b'const AI_RESTORED_STYLE', b'function normalizeAiHeroMarkup', b'prepareBriefPreviewHtml'):
    if marker not in original: raise SystemExit(f'Incompatible Briefs source; missing {marker.decode()}')
backup_target=backup/'web/src/lib/briefs.ts'; backup_target.parent.mkdir(parents=True,exist_ok=False); shutil.copy2(target,backup_target)
data=base64.b64decode(''); expected='b05405818961b47511e3f749c5bcb26a08e5bcfe7d649ac3cfe13bdcb0dbea62'
if hashlib.sha256(data).hexdigest()!=expected: raise SystemExit('Embedded source checksum mismatch')
tmp=target.with_name(target.name+'.compact-v44.tmp'); tmp.write_bytes(data); os.replace(tmp,target)
if hashlib.sha256(target.read_bytes()).hexdigest()!=expected: raise SystemExit('Installed source checksum mismatch')
focused=base64.b64decode(''); test=root/'web/src/lib/briefs.v44.test.ts'; test.write_bytes(focused)
print(f'SOURCE_REPLACEMENT_PASS={backup}')
PY
cd "$WEB"
npm test -- src/lib/briefs.v44.test.ts
rm -f "$FOCUSED_TEST"
npm run typecheck
npm run build
ASSET="$(find "$ROOT/hermes_cli/web_dist/assets" -maxdepth 1 -type f -name 'index-*.js' -print | sort | tail -n 1)"
if [[ -z "$ASSET" || ! -s "$ASSET" ]]; then echo "Built dashboard asset missing" >&2; exit 1; fi
trap - EXIT
echo "BRIEFS_AI_COMPACT_HEADER_V44_INSTALLED=PASS"
echo "Backup: $BACKUP"
echo "Asset: $ASSET"
echo "Refresh BRIEFS-AI on port 9120. No production listener was restarted."
