#!/usr/bin/env bash
set -euo pipefail
ROOT="/Users/jb3/.hermes/hermes-agent"
PYTHON="$ROOT/venv/bin/python"
WEB="$ROOT/web"
STAMP="$(date +%Y%m%d-%H%M%S)"
BACKUP="$HOME/.hermes/backups/briefs-ai-compact-header-v43-$STAMP"
if [[ ! -x "$PYTHON" ]]; then echo "Missing Hermes Python: $PYTHON" >&2; exit 1; fi
if [[ ! -f "$WEB/package.json" ]]; then echo "Missing Hermes web package: $WEB" >&2; exit 1; fi
restore() {
  if [[ -d "$BACKUP/web/src/lib" ]]; then
    cp "$BACKUP/web/src/lib/briefs.ts" "$ROOT/web/src/lib/briefs.ts"
    cp "$BACKUP/web/src/lib/briefs.test.ts" "$ROOT/web/src/lib/briefs.test.ts"
    (cd "$WEB" && npm run build) >/dev/null 2>&1 || true
    echo "RESTORED_AFTER_FAILURE=$BACKUP" >&2
  fi
}
trap 'r=$?; if [[ $r -ne 0 ]]; then restore; fi; exit $r' EXIT
"$PYTHON" - "$ROOT" "$BACKUP" <<'PY'
import base64, hashlib, os, shutil, sys, time
from pathlib import Path
root=Path(sys.argv[1])
backup=Path(sys.argv[2])
entries=[]
entries.append(('web/src/lib/briefs.ts','b05405818961b47511e3f749c5bcb26a08e5bcfe7d649ac3cfe13bdcb0dbea62',''))
entries.append(('web/src/lib/briefs.test.ts','eddfdd3b13bfbb37e11642edb2c870ab14df4306a6028114cb89ecedada23ad2',''))
backup.mkdir(parents=True, exist_ok=False)
for rel, expected, payload in entries:
    target=root/rel
    if not target.is_file(): raise SystemExit(f"Missing target: {target}")
    data=base64.b64decode(payload)
    if hashlib.sha256(data).hexdigest()!=expected: raise SystemExit(f"Embedded checksum mismatch: {rel}")
    saved=backup/rel
    saved.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(target,saved)
    tmp=target.with_name(target.name+".compact-v43.tmp")
    tmp.write_bytes(data)
    os.replace(tmp,target)
    if hashlib.sha256(target.read_bytes()).hexdigest()!=expected: raise SystemExit(f"Installed checksum mismatch: {rel}")
print(f"SOURCE_REPLACEMENT_PASS={backup}")
PY
cd "$WEB"
npm test -- src/lib/briefs.test.ts
npm run typecheck
npm run build
ASSET="$(find "$ROOT/hermes_cli/web_dist/assets" -maxdepth 1 -type f -name 'index-*.js' -print | sort | tail -n 1)"
if [[ -z "$ASSET" || ! -s "$ASSET" ]]; then echo "Built dashboard asset missing" >&2; exit 1; fi
trap - EXIT
echo "BRIEFS_AI_COMPACT_HEADER_V43_INSTALLED=PASS"
echo "Backup: $BACKUP"
echo "Asset: $ASSET"
echo "Refresh BRIEFS-AI on port 9120. No production listener was restarted."
