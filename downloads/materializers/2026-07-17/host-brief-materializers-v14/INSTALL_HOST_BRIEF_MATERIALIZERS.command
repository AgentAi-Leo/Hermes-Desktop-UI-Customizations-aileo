#!/bin/bash
set -euo pipefail

PROFILE_HOME="$HOME/.hermes/profiles/local-ai-assist1"
SCRIPTS="$PROFILE_HOME/scripts"
BACKUPS="$PROFILE_HOME/backups/brief-materializers"
STAMP="$(date +%Y%m%d-%H%M%S)"
mkdir -p "$SCRIPTS" "$BACKUPS/$STAMP"

if [ -e "$SCRIPTS/brief_materializer.py" ]; then cp -p "$SCRIPTS/brief_materializer.py" "$BACKUPS/$STAMP/brief_materializer.py"; fi
printf '%s' '' | base64 --decode > "$SCRIPTS/brief_materializer.py"

if [ -e "$SCRIPTS/materialize-briefs-ai.py" ]; then cp -p "$SCRIPTS/materialize-briefs-ai.py" "$BACKUPS/$STAMP/materialize-briefs-ai.py"; fi
printf '%s' 'IyEvdXNyL2Jpbi9lbnYgcHl0aG9uMwppbXBvcnQgc3lzCmZyb20gYnJpZWZfbWF0ZXJpYWxpemVyIGltcG9ydCBtYWluCnN5cy5hcmd2ID0gW3N5cy5hcmd2WzBdLCAiYWkiXQpyYWlzZSBTeXN0ZW1FeGl0KG1haW4oKSkK' | base64 --decode > "$SCRIPTS/materialize-briefs-ai.py"

if [ -e "$SCRIPTS/materialize-briefs-stock.py" ]; then cp -p "$SCRIPTS/materialize-briefs-stock.py" "$BACKUPS/$STAMP/materialize-briefs-stock.py"; fi
printf '%s' 'IyEvdXNyL2Jpbi9lbnYgcHl0aG9uMwppbXBvcnQgc3lzCmZyb20gYnJpZWZfbWF0ZXJpYWxpemVyIGltcG9ydCBtYWluCnN5cy5hcmd2ID0gW3N5cy5hcmd2WzBdLCAic3RvY2siXQpyYWlzZSBTeXN0ZW1FeGl0KG1haW4oKSkK' | base64 --decode > "$SCRIPTS/materialize-briefs-stock.py"

chmod 755 "$SCRIPTS/brief_materializer.py" "$SCRIPTS/materialize-briefs-ai.py" "$SCRIPTS/materialize-briefs-stock.py"
/Users/jb3/.hermes/hermes-agent/venv/bin/python -m py_compile "$SCRIPTS/brief_materializer.py" "$SCRIPTS/materialize-briefs-ai.py" "$SCRIPTS/materialize-briefs-stock.py"
printf 'HOST_BRIEF_MATERIALIZERS_INSTALLED=PASS\n'
printf 'Scripts: %s\n' "$SCRIPTS"
