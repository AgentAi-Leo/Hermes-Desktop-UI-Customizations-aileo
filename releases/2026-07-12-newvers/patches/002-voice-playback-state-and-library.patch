+/**
+ * Global Escape behavior for assistant audio. Deliberately ignores
+ * `defaultPrevented`: while playback is active, Escape must behave exactly like
+ * the visible stop/X control even if another UI handler saw the key first.
+ *
+ * Returns `true` when it handled the event (audio was active and has been
+ * stopped), so the caller can short-circuit any other Escape action. Returns
+ * `false` when there is no active playback, leaving Escape's normal behavior
+ * (closing overlays, exiting capture mode, blurring the composer) untouched.
+ */
+export function stopVoicePlaybackOnEscape(event: KeyboardEvent): boolean {
+  if (event.key !== 'Escape' || !isVoicePlaybackActive()) {
+    return false
+  }
+
+  event.preventDefault()
+  event.stopImmediatePropagation()
+  stopVoicePlayback()
+
+  return true
+}
+
+export function pauseVoicePlayback() {
+  const playback = $voicePlayback.get()
+
+  if (playback.status !== 'speaking' || !playback.audioElement) {
+    return
+  }
+
+  playback.audioElement.pause()
+  setVoicePlaybackState({ ...playback, status: 'paused' })
+}
+
+export async function resumeVoicePlayback(): Promise<void> {
+  const playback = $voicePlayback.get()
+
+  if (playback.status !== 'paused' || !playback.audioElement) {
+    return
+  }
+
+  setVoicePlaybackState({ ...playback, status: 'speaking' })
+  await playback.audioElement.play()
+}
+
