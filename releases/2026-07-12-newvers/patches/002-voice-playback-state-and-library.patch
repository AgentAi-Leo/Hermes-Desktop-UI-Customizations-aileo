+const VOLUME_KEY = 'hermes.desktop.voice.volume'
+const SPEED_KEY = 'hermes.desktop.voice.speed'
+
+export const $voiceVolume = atom(storedNumber(VOLUME_KEY, 1))
+
+$voiceVolume.subscribe(value => {
+  persistNumber(VOLUME_KEY, value)
+})
+
+/** Clamp 0–1 and persist; returns the clamped value. */
+export function setVoiceVolume(value: number): number {
+  const clamped = Math.min(1, Math.max(0, value))
+
+  $voiceVolume.set(clamped)
+
+  return clamped
+}
+
+/**
+ * TTS playback speed. Defaults to 1×, toggled to 2× via the playback pill.
+ * Persisted across sessions like volume.
+ */
+export const $voiceSpeed = atom(storedNumber(SPEED_KEY, 1))
+
+$voiceSpeed.subscribe(value => {
+  persistNumber(SPEED_KEY, value)
+})
+
+const SPEED_STEPS = [1, 1.5, 2]
+
+/** Cycle through 1× → 1.5× → 2× → 1×; returns the new value. */
+export function toggleVoiceSpeed(): number {
+  const current = $voiceSpeed.get()
+  const idx = SPEED_STEPS.findIndex(s => Math.abs(s - current) < 0.01)
+  const next = SPEED_STEPS[(idx + 1) % SPEED_STEPS.length] ?? 1
+
+  $voiceSpeed.set(next)
+
+  return next
+}
