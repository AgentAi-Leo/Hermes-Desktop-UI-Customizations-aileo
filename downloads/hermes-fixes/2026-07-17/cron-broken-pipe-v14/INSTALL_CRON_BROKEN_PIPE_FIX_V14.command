#!/bin/bash
set -euo pipefail
TARGET="/Users/jb3/.hermes/hermes-agent/hermes_cli/env_loader.py"
PYTHON="/Users/jb3/.hermes/hermes-agent/venv/bin/python"
ORIG_SHA="e33e716285a0cf472b5e68b47d629e2d0f8f8c1757057771c8aa3bd2fa07bfaf"
PATCHED_SHA="8f124152c2c491a86e23bd250d0f135fb081ba2bed38ddc4e416825fc58631f9"

[[ -f "$TARGET" ]] || { echo "ERROR: Missing $TARGET" >&2; exit 1; }
[[ -x "$PYTHON" ]] || { echo "ERROR: Missing $PYTHON" >&2; exit 1; }

"$PYTHON" - "$TARGET" "$ORIG_SHA" "$PATCHED_SHA" <<'PY'
from pathlib import Path
import ast, base64, datetime, hashlib, py_compile, shutil, sys
path=Path(sys.argv[1]); orig_sha=sys.argv[2]; patched_sha=sys.argv[3]
payload=base64.b64decode("")
if hashlib.sha256(payload).hexdigest()!=patched_sha:
    raise SystemExit("ERROR: embedded replacement checksum mismatch")
current=path.read_bytes(); current_sha=hashlib.sha256(current).hexdigest()
if current_sha==patched_sha:
    print("Already patched; verifying.")
elif current_sha==orig_sha:
    stamp=datetime.datetime.now().strftime("%Y%m%d-%H%M%S")
    backup=path.with_name(path.name+f".pre-broken-pipe-v14-{stamp}.bak")
    shutil.copy2(path,backup)
    tmp=path.with_name(path.name+".tmp-broken-pipe-v14")
    tmp.write_bytes(payload)
    py_compile.compile(str(tmp),doraise=True)
    tmp.replace(path)
    print(f"Backup: {backup}")
else:
    raise SystemExit(f"ERROR: Refusing to replace unknown env_loader.py checksum {current_sha}")

py_compile.compile(str(path),doraise=True)
module=ast.parse(path.read_text(encoding="utf-8"))
fn=next((n for n in module.body if isinstance(n,ast.FunctionDef) and n.name=="_safe_status_print"),None)
if fn is None: raise SystemExit("ERROR: safe helper missing")
ns={"sys":sys,"BrokenPipeError":BrokenPipeError,"OSError":OSError}
exec(compile(ast.Module(body=[fn],type_ignores=[]),str(path),"exec"),ns)
class ClosedPipe:
    def write(self,_text): raise BrokenPipeError(32,"Broken pipe")
    def flush(self): raise BrokenPipeError(32,"Broken pipe")
old=sys.stderr
try:
    sys.stderr=ClosedPipe(); ns["_safe_status_print"]("Bitwarden: applied secrets")
finally: sys.stderr=old
if hashlib.sha256(path.read_bytes()).hexdigest()!=patched_sha:
    raise SystemExit("ERROR: installed file checksum mismatch")
print("CRON_BROKEN_PIPE_ENV_LOADER_V14_INSTALLED=PASS")
PY
printf '%s
' 'Restart required: click Restart Gateway in the Hermes sidebar, then rerun the AI generator.'
