diff --git a/apps/desktop/src/styles.css b/apps/desktop/src/styles.css
index e5477bb6..0beaebec 100644
--- a/apps/desktop/src/styles.css
+++ b/apps/desktop/src/styles.css
@@ -360,7 +360,7 @@
     --sticky-human-top: 0.23rem;
     --file-tree-row-height: 1.375rem;
 
-    --composer-width: 48.75rem;
+    --composer-width: 65rem;
     --composer-control-size: 1.5rem;
     --composer-control-primary-size: 1.625rem;
     --composer-control-gap: 0.25rem;
@@ -1096,10 +1096,11 @@ text-* variant utilities. */ .btn-arc {
 }
 
 [data-slot='composer-root'] {
-  /* +10px width compensates the 5px side padding so the visible surface keeps
-     its exact width/position — the inline padding is just transparent grab space
-     for the peel-out drag, matching the floating composer's 5px platform. */
-  width: calc(min(var(--composer-width), calc(100% - 2rem)) + 10px);
+  /* Back to normal rail behavior. Do not force fixed/viewport positioning here. */
+  width: min(var(--composer-width), calc(100% - 2rem));
+  max-width: calc(100% - 2rem);
+  margin-inline: auto;
+  box-sizing: border-box;
   padding-inline: 5px;
   padding-bottom: var(--composer-shell-pad-block-end);
 }
@@ -1827,3 +1828,20 @@ text-* variant utilities. */ .btn-arc {
     opacity: 0.4;
   }
 }
+
+/* Fixed/floating composer <form> has max-width but no intrinsic width, so it can
+   shrink to content. Keep it anchored inside the chat pane instead of the whole
+   viewport, target --composer-width when space allows, shrink responsively when
+   a right-side pane/window reduces chat width, and sit as low as safely possible. */
+form[class~='group/composer'] {
+  /* Back to normal app-managed positioning. Only ensure responsive width. */
+  width: min(var(--composer-width), calc(100% - 2rem)) !important;
+  max-width: calc(100% - 2rem) !important;
+  min-width: 0 !important;
+  box-sizing: border-box !important;
+}
+
+/* Reserve scroll room so the final chat content can clear the composer/pill. */
+[data-slot='aui_thread-content'] {
+  padding-bottom: 210px !important;
+}
