#!/usr/bin/env bash
set -euo pipefail
PREVIEW="${HERMES_PREVIEW_ROOT:-$HOME/.hermes/zDownloads/_BRIEFS-DASHBOARD-V3-PREVIEW}"
AGENT_ROOT="${HERMES_AGENT_ROOT:-/Users/jb3/.hermes/hermes-agent}"
WEB="$PREVIEW/web"
DIST="$PREVIEW/hermes_cli/web_dist"
PYTHON="$AGENT_ROOT/venv/bin/python"
SOURCE="$WEB/src/lib/briefs.ts"
PAGE="$WEB/src/pages/BriefsPage.tsx"
FOCUSED_TEST="$WEB/src/lib/briefs.stock-v57.test.ts"
PROFILE="local-ai-assist1"
PORT="${HERMES_PREVIEW_PORT:-9120}"
STAMP="$(date +%Y%m%d-%H%M%S)"
BACKUP="$HOME/.hermes/backups/briefs-stocks-v57-macos-bash-$STAMP"
LOG="$HOME/.hermes/logs/briefs-stocks-v57-${PORT}.log"
BASE_SOURCE_SHA="dbfc3c00f59e8ea695876f3ee098792358135b8082cbbcba4545c8c678c5238b"
BASE_PAGE_SHA="a653042585914cd474d18a60af2f1a9af1a2940d288e1377c17d5a78cfe9aabf"
NEW_SOURCE_SHA="64fbc5542e2b7ba1a81ad464ad0866f78be58ad400ebf5b7aa9727d28fb67e5c"
NEW_PAGE_SHA="e47a8a47a14cacf0c100754d4488069d4b96baddef908ee117f5daa094a62d9b"
SERVER_TOUCHED=0

sha256_file() { shasum -a 256 "$1" | cut -d ' ' -f 1; }
stop_preview() {
  local pids i
  pids="$(lsof -tiTCP:"$PORT" -sTCP:LISTEN 2>/dev/null || true)"
  if [[ -n "$pids" ]]; then
    kill $pids 2>/dev/null || true
    for i in $(seq 1 50); do
      [[ -z "$(lsof -tiTCP:"$PORT" -sTCP:LISTEN 2>/dev/null || true)" ]] && return 0
      sleep 0.1
    done
    pids="$(lsof -tiTCP:"$PORT" -sTCP:LISTEN 2>/dev/null || true)"
    [[ -z "$pids" ]] || kill -9 $pids 2>/dev/null || true
  fi
}
start_preview() {
  mkdir -p "$(dirname "$LOG")"
  (cd "$PREVIEW" && nohup env PYTHONPATH="$PREVIEW" HERMES_WEB_DIST="$DIST" "$PYTHON" -m hermes_cli.main --profile "$PROFILE" dashboard --isolated --port "$PORT" --no-open >"$LOG" 2>&1 &)
}
wait_preview() {
  local i
  for i in $(seq 1 60); do
    curl -fsS "http://127.0.0.1:$PORT/" >/dev/null 2>&1 && return 0
    sleep 1
  done
  return 1
}
restore() {
  rm -f "$FOCUSED_TEST"
  if [[ -f "$BACKUP/web/src/lib/briefs.ts" ]]; then
    cp "$BACKUP/web/src/lib/briefs.ts" "$SOURCE"
    cp "$BACKUP/web/src/pages/BriefsPage.tsx" "$PAGE"
    rm -rf "$DIST"
    cp -R "$BACKUP/hermes_cli/web_dist" "$DIST"
    if [[ "$SERVER_TOUCHED" == "1" ]]; then
      stop_preview || true
      start_preview || true
      wait_preview || true
    fi
    echo "RESTORED_AFTER_FAILURE=$BACKUP" >&2
  fi
}
trap 'r=$?; if [[ $r -ne 0 ]]; then restore; else rm -f "$FOCUSED_TEST"; fi; exit $r' EXIT

for required in "$PYTHON" "$SOURCE" "$PAGE" "$WEB/package.json" "$DIST/index.html"; do
  [[ -e "$required" ]] || { echo "Missing required path: $required" >&2; exit 1; }
done
[[ -x "$PYTHON" ]] || { echo "Hermes Python is not executable: $PYTHON" >&2; exit 1; }

SOURCE_BEFORE="$(sha256_file "$SOURCE")"
PAGE_BEFORE="$(sha256_file "$PAGE")"
if [[ "$SOURCE_BEFORE" == "$NEW_SOURCE_SHA" && "$PAGE_BEFORE" == "$NEW_PAGE_SHA" ]]; then
  STATE="candidate"
elif [[ "$SOURCE_BEFORE" == "$BASE_SOURCE_SHA" && "$PAGE_BEFORE" == "$BASE_PAGE_SHA" ]]; then
  STATE="v52-baseline"
else
  echo "FAIL_CLOSED_INCOMPATIBLE_SOURCE" >&2
  echo "briefs.ts=$SOURCE_BEFORE" >&2
  echo "BriefsPage.tsx=$PAGE_BEFORE" >&2
  exit 1
fi

mkdir -p "$BACKUP/web/src/lib" "$BACKUP/web/src/pages" "$BACKUP/hermes_cli"
cp "$SOURCE" "$BACKUP/web/src/lib/briefs.ts"
cp "$PAGE" "$BACKUP/web/src/pages/BriefsPage.tsx"
cp -R "$DIST" "$BACKUP/hermes_cli/web_dist"

"$PYTHON" - "$SOURCE" "$PAGE" "$FOCUSED_TEST" <<'PY'
import base64, hashlib, os, sys
from pathlib import Path
items = [
    (Path(sys.argv[1]), '64fbc5542e2b7ba1a81ad464ad0866f78be58ad400ebf5b7aa9727d28fb67e5c', ''),
    (Path(sys.argv[2]), 'e47a8a47a14cacf0c100754d4488069d4b96baddef908ee117f5daa094a62d9b', ''),
    (Path(sys.argv[3]), '1df08263e37d1ba268d08f7ea5c10970d76ffb5ef519abd777472592ff0d504c', ''),
]
for target, expected, payload in items:
    data = base64.b64decode(payload)
    if hashlib.sha256(data).hexdigest() != expected:
        raise SystemExit(f'Embedded checksum mismatch: {target.name}')
    tmp = target.with_name(target.name + '.v53.tmp')
    tmp.write_bytes(data)
    os.replace(tmp, target)
    if hashlib.sha256(target.read_bytes()).hexdigest() != expected:
        raise SystemExit(f'Installed checksum mismatch: {target.name}')
PY

cd "$WEB"
npm test -- --run src/lib/briefs.stock-v57.test.ts
rm -f "$FOCUSED_TEST"
npm run typecheck
npm run build

"$PYTHON" - "$DIST" <<'PY'
import re, sys
from pathlib import Path
dist = Path(sys.argv[1])
index = (dist / 'index.html').read_text()
match = re.search(r'src="([^"]*index-[^"]+\.js)"', index)
if not match:
    raise SystemExit('Built JavaScript asset missing from index.html')
asset = dist / match.group(1).lstrip('./').lstrip('/')
data = asset.read_bytes()
for marker in (b'v53-stock-toolbar-parity', b'stock-toolbar', b'hermes-stock-date-navigation', b'v52-export-manifest-parity'):
    if marker not in data:
        raise SystemExit(f'Built asset missing marker: {marker.decode()}')
if b'hermes-stock-date-nav-controller' in data:
    raise SystemExit('Removed inline Stock date controller is still present')
print(f'BUILT_ASSET={asset.name}')
PY

if [[ "${SKIP_RESTART:-0}" != "1" ]]; then
  SERVER_TOUCHED=1
  stop_preview
  start_preview
  wait_preview || { echo "Preview did not become ready; see $LOG" >&2; exit 1; }
  LIVE_INDEX_FILE="$BACKUP/live-index.html"
  LIVE_JS_FILE="$BACKUP/live-asset.js"
  curl -fsS "http://127.0.0.1:$PORT/" -o "$LIVE_INDEX_FILE"
  LIVE_ASSET_PATH_FILE="$BACKUP/live-asset-path.txt"
  "$PYTHON" -c 'import re,sys; from pathlib import Path; html=Path(sys.argv[1]).read_text(); match=re.search(r"src=.(?P<asset>[^ >]*index-[^ >]+[.]js).", html); print(match.group("asset") if match else "")' "$LIVE_INDEX_FILE" > "$LIVE_ASSET_PATH_FILE"
  IFS= read -r LIVE_ASSET_PATH < "$LIVE_ASSET_PATH_FILE" || true
  [[ -n "$LIVE_ASSET_PATH" ]] || { echo "Live asset path missing; index saved at $LIVE_INDEX_FILE" >&2; exit 1; }
  curl -fsS "http://127.0.0.1:$PORT/${LIVE_ASSET_PATH#/}" -o "$LIVE_JS_FILE"
  "$PYTHON" - "$LIVE_JS_FILE" <<'PY'
import sys
from pathlib import Path
data = Path(sys.argv[1]).read_bytes()
for marker in (b'v53-stock-toolbar-parity', b'stock-toolbar', b'hermes-stock-date-navigation', b'v52-export-manifest-parity'):
    if marker not in data:
        raise SystemExit(f'Live asset missing marker: {marker.decode()}')
if b'hermes-stock-date-nav-controller' in data:
    raise SystemExit('Live asset contains removed Stock controller')
print(f'LIVE_ASSET={Path(sys.argv[1]).name}')
PY
  if [[ "${SKIP_OPEN:-0}" != "1" ]]; then
    open "http://127.0.0.1:$PORT/briefs-stocks?profile=$PROFILE&stocks=working-preview&candidate=v57-$(date +%s)"
  fi
fi

SOURCE_AFTER="$(sha256_file "$SOURCE")"
PAGE_AFTER="$(sha256_file "$PAGE")"
[[ "$SOURCE_AFTER" == "$NEW_SOURCE_SHA" && "$PAGE_AFTER" == "$NEW_PAGE_SHA" ]] || { echo "Final source verification failed" >&2; exit 1; }
trap - EXIT
rm -f "$FOCUSED_TEST"
echo "BRIEFS_STOCKS_V57_MACOS_BASH=PASS"
echo "SOURCE_STATE_BEFORE=$STATE"
echo "PREVIEW_ROOT=$PREVIEW"
echo "HOST_HERMES_SOURCE=UNTOUCHED"
echo "TESTS=40/40"
echo "BACKUP=$BACKUP"
echo "PREVIEW=http://127.0.0.1:$PORT/briefs-stocks?profile=$PROFILE&stocks=working-preview"
